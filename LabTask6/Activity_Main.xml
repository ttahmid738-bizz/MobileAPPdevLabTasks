<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#1E1E1E"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="The Daily Reader"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/bookmarkBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/btn_star_big_off"
            android:tint="#FFFFFF"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:id="@+id/shareBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_share"
            android:tint="#FFFFFF"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_report_image"/>

            <TextView
                android:id="@+id/category"
                android:text="TECHNOLOGY"
                android:padding="6dp"
                android:background="#FF5722"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/title"
                android:text="The Future of Artificial Intelligence in Daily Life"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/sym_def_app_icon"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  By Admin"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  • 16 Apr 2026"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="10dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <Button android:id="@+id/btnIntro" android:text="Intro"/>
                    <Button android:id="@+id/btnKey" android:text="Key Points"/>
                    <Button android:id="@+id/btnAnalysis" android:text="Analysis"/>
                    <Button android:id="@+id/btnConclusion" android:text="Conclusion"/>

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/intro"
                android:text="Introduction..."
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>

            <TextView
                android:text="(150+ words article content goes here...)"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/key"
                android:text="Key Points"
                android:textStyle="bold"/>

            <TextView
                android:text="(150+ words content...)"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/analysis"
                android:text="Analysis"
                android:textStyle="bold"/>

            <TextView
                android:text="(150+ words content...)"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/conclusion"
                android:text="Conclusion"
                android:textStyle="bold"/>

            <TextView
                android:text="(150+ words content...)"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:text="Tags:"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <HorizontalScrollView>

                <LinearLayout
                    android:orientation="horizontal">

                    <Button android:text="AI"/>
                    <Button android:text="Tech"/>
                    <Button android:text="Future"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:text="Related Articles"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <LinearLayout
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:orientation="vertical">
                    <ImageView android:layout_width="match_parent" android:layout_height="80dp"/>
                    <TextView android:text="AI News 1"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:orientation="vertical">
                    <ImageView android:layout_width="match_parent" android:layout_height="80dp"/>
                    <TextView android:text="AI News 2"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:orientation="vertical">
                    <ImageView android:layout_width="match_parent" android:layout_height="80dp"/>
                    <TextView android:text="AI News 3"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ImageButton
        android:id="@+id/topBtn"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@android:drawable/arrow_up_float"
        android:background="#00000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>