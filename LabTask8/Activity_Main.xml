<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#222"
        android:gravity="center_vertical"
        android:padding="6dp">

        <Button android:id="@+id/backBtn" android:text="◀"/>
        <Button android:id="@+id/forwardBtn" android:text="▶"/>
        <Button android:id="@+id/refreshBtn" android:text="🔄"/>
        <Button android:id="@+id/homeBtn" android:text="🏠"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp">

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter URL"/>

        <Button
            android:id="@+id/goBtn"
            android:text="Go"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:visibility="gone"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <Button android:id="@+id/googleBtn" android:text="Google"/>
            <Button android:id="@+id/youtubeBtn" android:text="YouTube"/>
            <Button android:id="@+id/wikiBtn" android:text="Wikipedia"/>
            <Button android:id="@+id/khanBtn" android:text="Khan Academy"/>
            <Button android:id="@+id/uniBtn" android:text="University"/>

        </LinearLayout>
    </HorizontalScrollView>

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>